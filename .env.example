# Zeitzone (für alle Container – Portal, Celery-Worker, Logs)
TZ=Europe/Berlin

# Alle weiteren Einstellungen werden beim ersten Start über den Setup-Wizard konfiguriert.

# Proxmox
# PROXMOX_HOST=https://proxmox.example.com:8006
# PROXMOX_NODE=pve1
# PROXMOX_VERIFY_SSL=true

# Backend
SECRET_KEY=change-me-min-32-chars-random-string # openssl rand -base64 32

# Lokaler Admin-Account (PROJ-8: Hybrid Auth)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-before-first-start

# PROJ-10: Service-Account API-Tokens
# PROXMOX_VIEWER_TOKEN_ID=portal-viewer@pve!portal-viewer
# PROXMOX_VIEWER_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROXMOX_OPERATOR_TOKEN_ID=portal-operator@pve!portal-operator
# PROXMOX_OPERATOR_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROXMOX_ADMIN_TOKEN_ID=portal-admin@pve!portal-admin
# PROXMOX_ADMIN_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# PROJ-6: Packer API-Token
# PACKER_TOKEN_ID=packer@pve!portal-packer
# PACKER_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PACKER_HTTP_IP=192.168.1.100

# PROJ-23: Proxmox API Audit-Log (optional)
# PROXMOX_AUDIT_ENABLED=1
# PROXMOX_AUDIT_LOG_BODY=1
# PROXMOX_AUDIT_DEBUG_USER=1

# Optional
# DATA_DIR=/app/data
# ANSIBLE_DIR=/app/ansible
